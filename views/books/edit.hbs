<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h3><i class="fas fa-edit"></i> Editar Libro</h3>
            </div>
            <div class="card-body">
                <form action="/books/edit/{{book.id}}" method="POST" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="title" class="form-label">Título *</label>
                        <input type="text" class="form-control" id="title" name="title" value="{{book.title}}" required>
                    </div>
                    
                    <div class="mb-3">
                        <label for="publicationYear" class="form-label">Año de Publicación *</label>
                        <input type="number" class="form-control" id="publicationYear" name="publicationYear" 
                               value="{{book.publicationYear}}" min="1000" max="{{currentYear}}" required>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Imagen Actual</label>
                        <div>
                            {{#if book.coverImage}}
                            <img src="{{book.coverImage}}" alt="{{book.title}}" style="width: 100px; height: 100px; object-fit: cover;">
                            {{else}}
                            <i class="fas fa-book fa-3x text-secondary"></i>
                            {{/if}}
                        </div>
                        <label for="coverImage" class="form-label mt-2">Cambiar Imagen de Portada</label>
                        <input type="file" class="form-control" id="coverImage" name="coverImage" accept="image/*">
                        <small class="text-muted">Formatos permitidos: JPG, PNG, GIF (Máx. 5MB)</small>
                    </div>
                    
                    <div class="mb-3">
                        <label for="categoryId" class="form-label">Categoría *</label>
                        <select class="form-select" id="categoryId" name="categoryId" required>
                            <option value="">Seleccione una categoría</option>
                            {{#each categories}}
                            <option value="{{id}}" {{#if (eq ../book.category.id id)}}selected{{/if}}>{{name}}</option>
                            {{/each}}
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label for="authorId" class="form-label">Autor *</label>
                        <select class="form-select" id="authorId" name="authorId" required>
                            <option value="">Seleccione un autor</option>
                            {{#each authors}}
                            <option value="{{id}}" {{#if (eq ../book.author.id id)}}selected{{/if}}>{{name}} ({{email}})</option>
                            {{/each}}
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label for="publisherId" class="form-label">Editorial *</label>
                        <select class="form-select" id="publisherId" name="publisherId" required>
                            <option value="">Seleccione una editorial</option>
                            {{#each publishers}}
                            <option value="{{id}}" {{#if (eq ../book.publisher.id id)}}selected{{/if}}>{{name}}</option>
                            {{/each}}
                        </select>
                    </div>
                    
                    <div class="d-flex justify-content-between">
                        <a href="/books" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Volver
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Guardar Cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>