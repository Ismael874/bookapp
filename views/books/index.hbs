<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="fas fa-book"></i> Mantenimiento de Libros</h1>
    <a href="/books/create" class="btn btn-success">
        <i class="fas fa-plus"></i> Nuevo Libro
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Título</th>
                <th>Portada</th>
                <th>Año</th>
                <th>Categoría</th>
                <th>Autor</th>
                <th>Editorial</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            {{#each books}}
            <tr>
                <td>{{title}}</td>
                <td>
                    {{#if coverImage}}
                    <img src="{{coverImage}}" alt="{{title}}" style="width: 50px; height: 50px; object-fit: cover;">
                    {{else}}
                    <i class="fas fa-book fa-2x text-secondary"></i>
                    {{/if}}
                </td>
                <td>{{publicationYear}}</td>
                <td>{{category.name}}</td>
                <td>{{author.name}}</td>
                <td>{{publisher.name}}</td>
                <td>
                    <a href="/books/edit/{{id}}" class="btn btn-warning btn-sm">
                        <i class="fas fa-edit"></i>
                    </a>
                    <a href="/books/delete/{{id}}" class="btn btn-danger btn-sm">
                        <i class="fas fa-trash"></i>
                    </a>
                </td>
            </tr>
            {{else}}
            <tr>
                <td colspan="7" class="text-center">No hay libros registrados</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>