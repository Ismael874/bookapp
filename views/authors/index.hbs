<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="fas fa-users"></i> Mantenimiento de Autores</h1>
    <a href="/authors/create" class="btn btn-success">
        <i class="fas fa-plus"></i> Nuevo Autor
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Email</th>
                <th>Cantidad de Libros</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            {{#each authors}}
            <tr>
                <td>{{name}}</td>
                <td>{{email}}</td>
                <td>{{bookCount}}</td>
                <td>
                    <a href="/authors/edit/{{id}}" class="btn btn-warning btn-sm">
                        <i class="fas fa-edit"></i>
                    </a>
                    <a href="/authors/delete/{{id}}" class="btn btn-danger btn-sm">
                        <i class="fas fa-trash"></i>
                    </a>
                </td>
            </tr>
            {{else}}
            <tr>
                <td colspan="4" class="text-center">No hay autores registrados</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>