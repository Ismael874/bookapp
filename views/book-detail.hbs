<div class="row">
    <div class="col-md-4">
        <div class="card">
            {{#if book.coverImage}}
            <img src="{{book.coverImage}}" class="card-img-top" alt="{{book.title}}">
            {{else}}
            <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 300px;">
                <i class="fas fa-book fa-5x text-white"></i>
            </div>
            {{/if}}
            <div class="card-body">
                <a href="/" class="btn btn-secondary w-100">
                    <i class="fas fa-arrow-left"></i> Volver al inicio
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h2>{{book.title}}</h2>
            </div>
            <div class="card-body">
                <table class="table">
                    <tr>
                        <th>Año de publicación:</th>
                        <td>{{book.publicationYear}}</td>
                    </tr>
                    <tr>
                        <th>Categoría:</th>
                        <td>{{book.category.name}}</td>
                    </tr>
                    <tr>
                        <th>Autor:</th>
                        <td>{{book.author.name}}</td>
                    </tr>
                    <tr>
                        <th>Editorial:</th>
                        <td>{{book.publisher.name}}</td>
                    </tr>
                    <tr>
                        <th>País de la editorial:</th>
                        <td>{{book.publisher.country}}</td>
                    </tr>
                    <tr>
                        <th>Teléfono de la editorial:</th>
                        <td>{{book.publisher.phone}}</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>