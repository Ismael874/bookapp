<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="fas fa-building"></i> Mantenimiento de Editoriales</h1>
    <a href="/publishers/create" class="btn btn-success">
        <i class="fas fa-plus"></i> Nueva Editorial
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Teléfono</th>
                <th>País</th>
                <th>Cantidad de Libros</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            {{#each publishers}}
            <tr>
                <td>{{name}}</td>
                <td>{{phone}}</td>
                <td>{{country}}</td>
                <td>{{bookCount}}</td>
                <td>
                    <a href="/publishers/edit/{{id}}" class="btn btn-warning btn-sm">
                        <i class="fas fa-edit"></i>
                    </a>
                    <a href="/publishers/delete/{{id}}" class="btn btn-danger btn-sm">
                        <i class="fas fa-trash"></i>
                    </a>
                </td>
            </tr>
            {{else}}
            <tr>
                <td colspan="5" class="text-center">No hay editoriales registradas</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>